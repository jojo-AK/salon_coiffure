# ============================================================
# DEV (local) — copier vers .env
# ============================================================
FLASK_ENV=development
SECRET_KEY=change-this-in-production

# Mail (optionnel)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ton_email@gmail.com
MAIL_PASSWORD=ton_app_password

# ============================================================
# PROD (Render) — à renseigner dans le dashboard Render,
# PAS dans un .env commité.
# ============================================================
# FLASK_ENV=production
# SECRET_KEY=<générer avec: python -c "import secrets; print(secrets.token_hex(32))">
# DATABASE_URL=<fourni automatiquement par Render quand tu lies une DB>
# ADMIN_EMAIL=coiffeur@salon.com
# ADMIN_PASSWORD=<mot de passe fort>
# ADMIN_NOM=Joseph Coiffeur
